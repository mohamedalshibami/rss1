{
  "version": 2,
  "builds": [
    {
      "src": "api/rss.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/grid",
      "dest": "api/rss.py"
    },
    {
      "src": "/extract",
      "dest": "api/rss.py"
    },
    {
      "src": "/rss",
      "dest": "api/rss.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
